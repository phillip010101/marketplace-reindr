---
export const prerender = true;
const canonicalUrl = 'http://localhost:4321/panel';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Panel proveedor | Reindr Marketplace MVP</title>
    <meta
      name="description"
      content="Panel operativo para proveedores: acceso, metricas base y atajos de gestion."
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <main style="max-width: 1080px; margin: 0 auto; padding: 40px 20px; font-family: system-ui, sans-serif;">
      <header style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap;">
        <div>
          <p style="margin:0; text-transform:uppercase; letter-spacing:.08em; font-size:12px;">Provider workspace</p>
          <h1 style="margin:8px 0 0;">Panel proveedor</h1>
        </div>
        <nav style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
          <a href="/panel">Dashboard</a>
          <a href="/panel/perfil">Perfil</a>
          <a href="/panel/leads">Leads</a>
          <button id="logout-btn" type="button">Cerrar sesion</button>
        </nav>
      </header>

      <section style="margin-top:20px; border:1px solid #ddd; border-radius:14px; padding:16px;">
        <h2 style="margin-top:0;">Sesion</h2>
        <p style="margin-top:0;">Panel protegido por autenticacion provider (bearer token).</p>
        <p id="auth-status" style="margin:12px 0 0; font-size:14px;"></p>
      </section>

      <section style="margin-top:24px;">
        <h2>Metricas rapidas</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px;">
          <article style="border:1px solid #ddd; border-radius:12px; padding:14px;">
            <p style="margin:0; font-size:13px;">Leads nuevos</p>
            <strong id="metric-new" style="font-size:28px;">-</strong>
          </article>
          <article style="border:1px solid #ddd; border-radius:12px; padding:14px;">
            <p style="margin:0; font-size:13px;">Leads contactados</p>
            <strong id="metric-contacted" style="font-size:28px;">-</strong>
          </article>
          <article style="border:1px solid #ddd; border-radius:12px; padding:14px;">
            <p style="margin:0; font-size:13px;">Cotizaciones enviadas</p>
            <strong id="metric-quoted" style="font-size:28px;">-</strong>
          </article>
          <article style="border:1px solid #ddd; border-radius:12px; padding:14px;">
            <p style="margin:0; font-size:13px;">Cierres reportados</p>
            <strong id="metric-closed" style="font-size:28px;">-</strong>
          </article>
        </div>
      </section>

      <section style="margin-top:24px; border:1px solid #ddd; border-radius:12px; padding:16px;">
        <h2 style="margin-top:0;">Recomendaciones operativas</h2>
        <ul>
          <li>Actualiza tu perfil para mejorar conversion en solicitudes publicas.</li>
          <li>Responde leads nuevos en menos de 24 horas.</li>
          <li>Registra cotizacion solo cuando tengas alcance y tiempos claros.</li>
        </ul>
      </section>
    </main>

    <script>
      import {
        apiRequest,
        ensureProviderSession,
        clearStoredAccessToken,
        providerAuthHeaders
      } from '../../scripts/provider-panel-client';

      type ProviderMetrics = {
        total: number;
        new: number;
        contacted: number;
        quoted: number;
        closed: number;
      };

      const logoutButton = document.querySelector<HTMLButtonElement>('#logout-btn');
      const authStatus = document.querySelector<HTMLElement>('#auth-status');
      const metricNew = document.querySelector<HTMLElement>('#metric-new');
      const metricContacted = document.querySelector<HTMLElement>('#metric-contacted');
      const metricQuoted = document.querySelector<HTMLElement>('#metric-quoted');
      const metricClosed = document.querySelector<HTMLElement>('#metric-closed');

      function setStatus(message: string, tone: 'neutral' | 'error' | 'ok' = 'neutral') {
        if (!authStatus) return;
        authStatus.textContent = message;
        authStatus.style.color = tone === 'error' ? '#a40000' : tone === 'ok' ? '#0b5d1e' : '#333';
      }

      function setMetrics(metrics: ProviderMetrics) {
        if (metricNew) metricNew.textContent = String(metrics.new);
        if (metricContacted) metricContacted.textContent = String(metrics.contacted);
        if (metricQuoted) metricQuoted.textContent = String(metrics.quoted);
        if (metricClosed) metricClosed.textContent = String(metrics.closed);
      }

      async function refreshMetrics() {
        const session = await ensureProviderSession({
          redirectToLogin: true
        });
        if (!session.ok) {
          return;
        }

        const result = await apiRequest<ProviderMetrics>('/api/provider/metrics', {
          headers: {
            ...providerAuthHeaders()
          }
        });

        if (!result.ok) {
          setStatus('No se pudieron cargar metricas. Verifica token provider.', 'error');
          return;
        }

        const metrics = (result.data ?? {
          total: 0,
          new: 0,
          contacted: 0,
          quoted: 0,
          closed: 0
        }) as ProviderMetrics;
        setMetrics(metrics);
        setStatus(`Sesion activa. Oportunidades cargadas: ${metrics.total}.`, 'ok');
      }

      logoutButton?.addEventListener('click', () => {
        clearStoredAccessToken();
        if (metricNew) metricNew.textContent = '-';
        if (metricContacted) metricContacted.textContent = '-';
        if (metricQuoted) metricQuoted.textContent = '-';
        if (metricClosed) metricClosed.textContent = '-';
        window.location.href = '/panel/login';
      });

      refreshMetrics();
    </script>
  </body>
</html>
