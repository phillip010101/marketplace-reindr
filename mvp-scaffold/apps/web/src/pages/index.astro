---
export const prerender = true;
import { SERVICES } from '../data/catalog';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Red de servicios conectados | Reindr Marketplace MVP</title>
    <meta name="description" content="Encuentra proveedores y solicita cotizaciones para servicios relacionados en tu ciudad." />
    <link rel="canonical" href="http://localhost:4321/" />
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <main style="max-width: 960px; margin: 0 auto; padding: 48px 20px; font-family: system-ui, sans-serif;">
      <section>
        <p style="text-transform: uppercase; letter-spacing: .08em; font-size: 12px;">Marketplace local de servicios</p>
        <h1>Encuentra proveedores y arma solicitudes multi-servicio</h1>
        <p>Busca un servicio principal y anade servicios complementarios como diseno, troquel, impresion, etiquetas o ecommerce.</p>

        <form action="/bogota/cajas-personalizadas" method="get" style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 24px;">
          <input name="q" placeholder="Que necesitas?" style="padding: 12px; min-width: 240px;" />
          <button style="padding: 12px 16px;">Buscar</button>
        </form>
      </section>

      <section style="margin-top: 48px;">
        <h2>Servicios iniciales</h2>
        <p><a href="/servicios">Ver todos los servicios</a></p>
        <div style="display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
          {SERVICES.slice(0, 6).map((service) => (
            <a href={`/bogota/${service.slug}`} style="border: 1px solid #ddd; border-radius: 12px; padding: 16px; text-decoration: none; color: inherit;">
              <strong>{service.name}</strong>
              <p>Ver proveedores en Bogota</p>
            </a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
