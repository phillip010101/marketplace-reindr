NODE_ENV=development

DATABASE_URL=postgres://reindr:reindr@localhost:5432/reindr_marketplace

WEB_PORT=4321
API_PORT=8787
PUBLIC_API_BASE_URL=http://localhost:8787

SESSION_SECRET=change-me
LEADS_RATE_LIMIT_MAX=20
LEADS_RATE_LIMIT_WINDOW_MS=60000

# Contract RAG auto-preflight behavior:
# - full: init + validate + index + context (default)
# - baseline: init only (faster)
CONTRACT_RAG_ENSURE_MODE=full
CONTRACT_RAG_ENSURE_TASK=workspace preflight contract sync
